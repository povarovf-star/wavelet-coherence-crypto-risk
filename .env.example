# Optional TradingView authentication. Public quotes work without it.
# Treat these session cookies like a password: never commit, archive, or share
# a populated .env. Revoke active TradingView sessions if a cookie is exposed.
# Copy the values from your own TradingView session cookies:
#   sessionid      -> TV_SESSION
#   sessionid_sign -> TV_SIGNATURE
TV_SESSION=
TV_SIGNATURE=

# Optional alert destinations used by `npm run tv -- alert ...`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
